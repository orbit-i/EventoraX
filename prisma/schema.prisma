generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ------------------------------
// ENUMS
// ------------------------------

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

// Matches spec exactly: Draft, Upcoming, Active, Completed, Archived
enum EventStatus {
  DRAFT
  PUBLISHED   // "Upcoming" in spec
  ONGOING     // "Active" in spec
  COMPLETED
  ARCHIVED
}

// Matches spec exactly: Registered, Attended, Absent, Cancelled
enum RegistrationStatus {
  REGISTERED
  ATTENDED
  ABSENT
  CANCELLED
}

enum RegisteredVia {
  WEB
  ADMIN
  CSV_IMPORT
  API
}

enum SponsorTier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

// ------------------------------
// MODELS
// ------------------------------

model Event {
  id               String      @id @default(cuid())
  tenantId         String
  title            String
  organizer        String?
  mode             EventMode
  startDateTime    DateTime
  endDateTime      DateTime
  location         String?
  description      String?     @db.Text
  topic            String?
  maxAttendees     Int?
  ticketPrice      Decimal?    @db.Decimal(10, 2)
  registrationOpen Boolean     @default(true)
  meetingLink      String?
  certTemplateId   String?     // owned by Isha's Certificates module — id only, no local FK
  autoIssueCert    Boolean     @default(false)
  status           EventStatus @default(DRAFT)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  categories    EventCategory[]
  registrations Registration[]
  speakers      Speaker[]
  sponsors      Sponsor[]
  sessions      Session[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("events")
}

// Per-event configurable categories (e.g. General, VIP, Speaker, Student...).
// Replaces the old hardcoded global RegistrationCategory enum.
model EventCategory {
  id      String @id @default(cuid())
  tenantId String
  eventId String
  label   String

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@unique([eventId, label])
  @@index([tenantId])
  @@index([eventId])
  @@map("event_categories")
}

model Registration {
  id               String              @id @default(cuid())
  tenantId         String
  eventId          String
  categoryId       String?
  refNo            String              @unique
  name             String
  email            String
  phone            String?
  department       String?
  rollNo           String?
  registeredVia    RegisteredVia       @default(WEB)
  status           RegistrationStatus  @default(REGISTERED)
  registrationDate DateTime            @default(now())
  ticketId         String?             // owned by Isha's QR Tickets module — id only, no local FK
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category EventCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([eventId, email]) // blocks duplicate registration to the same event
  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, status])
  @@map("registrations")
}

model Speaker {
  id           String   @id @default(cuid())
  tenantId     String
  eventId      String
  firstName    String
  lastName     String
  title        String?
  company      String?
  sessionTopic String?
  bio          String?  @db.Text
  photo        String?
  linkedin     String?
  displayPublic Boolean @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([tenantId])
  @@index([eventId])
  @@map("speakers")
}

model Sponsor {
  id           String      @id @default(cuid())
  tenantId     String
  eventId      String
  name         String
  website      String?
  logo         String?
  tier         SponsorTier @default(BRONZE)
  displayPublic Boolean    @default(false)
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, tier])
  @@map("sponsors")
}

model Session {
  id            String   @id @default(cuid())
  tenantId      String
  eventId       String
  speakerId     String?
  title         String
  startTime     DateTime
  endTime       DateTime
  location      String?
  displayPublic Boolean  @default(false)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([eventId])
  @@map("sessions")
}
