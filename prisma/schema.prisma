generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ------------------------------
// ENUMS
// ------------------------------

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
  ATTENDED
}

enum RegisteredVia {
  WEB
  ADMIN
  CSV_IMPORT
  API
}

enum RegistrationCategory {
  STUDENT
  FACULTY
  PROFESSIONAL
  GUEST
}

enum SponsorTier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

// ------------------------------
// MODELS
// ------------------------------

model Event {
  id               String      @id @default(cuid())
  tenantId         String
  title            String
  mode             EventMode
  startDateTime    DateTime
  endDateTime      DateTime
  location         String?
  description      String?     @db.Text
  topic            String?
  maxAttendees     Int?
  ticketPrice      Decimal?    @db.Decimal(10, 2)
  registrationOpen Boolean     @default(true)
  meetingLink      String?
  certTemplateId   String?
  autoIssueCert    Boolean     @default(false)
  status           EventStatus @default(DRAFT)
  createdAt        DateTime    @default(now())

  registrations Registration[]
  speakers      Speaker[]
  sponsors      Sponsor[]
  sessions      Session[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("events")
}

model Registration {
  id               String               @id @default(cuid())
  tenantId         String
  eventId          String
  refNo            String               @unique
  name             String
  email            String
  phone            String?
  department       String?
  rollNo           String?
  category         RegistrationCategory @default(GUEST)
  registeredVia    RegisteredVia        @default(WEB)
  status           RegistrationStatus   @default(PENDING)
  registrationDate DateTime             @default(now())
  ticketId         String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, status])
  @@map("registrations")
}

model Speaker {
  id           String  @id @default(cuid())
  tenantId     String
  eventId      String
  firstName    String
  lastName     String
  title        String?
  company      String?
  sessionTopic String?
  bio          String? @db.Text
  photo        String?
  linkedin     String?
  displayOrder Int     @default(0)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([tenantId])
  @@index([eventId])
  @@map("speakers")
}

model Sponsor {
  id           String      @id @default(cuid())
  tenantId     String
  eventId      String
  name         String
  contactEmail String?
  website      String?
  logo         String?
  tier         SponsorTier @default(BRONZE)
  displayOrder Int         @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, tier])
  @@map("sponsors")
}

model Session {
  id           String   @id @default(cuid())
  tenantId     String
  eventId      String
  speakerId    String?
  title        String
  startTime    DateTime
  endTime      DateTime
  location     String?
  displayOrder Int      @default(0)

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([eventId])
  @@map("sessions")
}
